<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:OpenSourceTree.Views"
             x:Class="OpenSourceTree.Views.RepositoryView">

    <DockPanel>

        <!-- ===== Toolbar ===== -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource B.Toolbar}"
                BorderBrush="{DynamicResource B.Border}" BorderThickness="0,0,0,1">
            <DockPanel Margin="6,4">
                <!-- right-aligned tools -->
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="2">
                    <Button Classes="toolbar" Command="{Binding GitFlowCommand}" ToolTip.Tip="Git Flow: start or finish feature / release / hotfix branches">
                        <StackPanel Spacing="3">
                            <Image Source="{DynamicResource I.GitFlow}" Width="16" Height="16" />
                            <TextBlock Text="{DynamicResource L.GitFlow}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar" Command="{Binding OpenTerminalCommand}" ToolTip.Tip="Open a terminal in this repository">
                        <StackPanel Spacing="3">
                            <Image Source="{DynamicResource I.Terminal}" Width="16" Height="16" />
                            <TextBlock Text="{DynamicResource L.Terminal}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar" Command="{Binding OpenExplorerCommand}" ToolTip.Tip="Open in file manager">
                        <StackPanel Spacing="3">
                            <Image Source="{DynamicResource I.Explorer}" Width="16" Height="16" />
                            <TextBlock Text="{DynamicResource L.Explorer}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar" Command="{Binding OpenSettingsCommand}" ToolTip.Tip="Repository settings">
                        <StackPanel Spacing="3">
                            <Image Source="{DynamicResource I.Settings}" Width="16" Height="16" />
                            <TextBlock Text="{DynamicResource L.Settings}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- main actions -->
                <StackPanel Orientation="Horizontal" Spacing="2">
                    <Button Classes="toolbar" Command="{Binding ShowCommitViewCommand}" ToolTip.Tip="Commit pending changes">
                        <StackPanel Spacing="3">
                            <Image Source="{DynamicResource I.Commit}" Width="16" Height="16" />
                            <TextBlock Text="{DynamicResource L.Commit}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar" Command="{Binding PullCommand}" ToolTip.Tip="Pull from remote">
                        <StackPanel Spacing="3">
                            <Image Source="{DynamicResource I.Pull}" Width="16" Height="16" />
                            <TextBlock Text="{DynamicResource L.Pull}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar" Command="{Binding PushCommand}" ToolTip.Tip="Push to remote">
                        <StackPanel Spacing="3">
                            <Image Source="{DynamicResource I.Push}" Width="16" Height="16" />
                            <TextBlock Text="{DynamicResource L.Push}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar" Command="{Binding FetchCommand}" ToolTip.Tip="Fetch from all remotes">
                        <StackPanel Spacing="3">
                            <Image Source="{DynamicResource I.Fetch}" Width="16" Height="16" />
                            <TextBlock Text="{DynamicResource L.Fetch}" />
                        </StackPanel>
                    </Button>

                    <Border Width="1" Background="{DynamicResource B.Divider}" Margin="4,6" />

                    <Button Classes="toolbar" Command="{Binding NewBranchCommand}" ToolTip.Tip="Create a new branch">
                        <StackPanel Spacing="3">
                            <Image Source="{DynamicResource I.Branch}" Width="16" Height="16" />
                            <TextBlock Text="{DynamicResource L.Branch}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar" Command="{Binding MergeCommand}" ToolTip.Tip="Merge a branch into the current branch">
                        <StackPanel Spacing="3">
                            <Image Source="{DynamicResource I.Merge}" Width="16" Height="16" />
                            <TextBlock Text="{DynamicResource L.Merge}" />
                        </StackPanel>
                    </Button>

                    <Border Width="1" Background="{DynamicResource B.Divider}" Margin="4,6" />

                    <Button Classes="toolbar" Command="{Binding StashChangesCommand}" ToolTip.Tip="Stash working copy changes">
                        <StackPanel Spacing="3">
                            <Image Source="{DynamicResource I.Stash}" Width="16" Height="16" />
                            <TextBlock Text="{DynamicResource L.Stash}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar" Command="{Binding DiscardAllCommand}" ToolTip.Tip="Discard all unstaged changes">
                        <StackPanel Spacing="3">
                            <Image Source="{DynamicResource I.Discard}" Width="16" Height="16" />
                            <TextBlock Text="{DynamicResource L.Discard}" />
                        </StackPanel>
                    </Button>
                    <Button Classes="toolbar" Command="{Binding NewTagCommand}" ToolTip.Tip="Tag the current commit">
                        <StackPanel Spacing="3">
                            <Image Source="{DynamicResource I.Tag}" Width="16" Height="16" />
                            <TextBlock Text="{DynamicResource L.Tag}" />
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <ProgressBar DockPanel.Dock="Top" IsIndeterminate="True" Height="2" MinHeight="2"
                     IsVisible="{Binding IsBusy}" Background="Transparent" Foreground="#4A9EE0" />

        <!-- ===== Sidebar + content ===== -->
        <Grid ColumnDefinitions="230,4,*">

            <Border Grid.Column="0" Background="{DynamicResource B.Panel}">
                <ScrollViewer>
                    <StackPanel Margin="6,8" Spacing="2">

                        <StackPanel Orientation="Horizontal" Spacing="7" Margin="8,2,0,4">
                            <Image Source="{DynamicResource I.Workspace}" Width="14" Height="14" />
                            <TextBlock Classes="sectionHeader" Text="{DynamicResource L.Workspace}" VerticalAlignment="Center" />
                        </StackPanel>

                        <Button Classes="navItem" Classes.selected="{Binding IsFileStatusNavSelected}"
                                Command="{Binding SelectSectionCommand}" CommandParameter="FileStatus">
                            <DockPanel>
                                <Border DockPanel.Dock="Right" Background="{DynamicResource B.Accent}" CornerRadius="8"
                                        Padding="6,1" IsVisible="{Binding HasPending}">
                                    <TextBlock Text="{Binding PendingCount}" FontSize="10" Foreground="White" />
                                </Border>
                                <TextBlock Text="{DynamicResource L.FileStatus}" />
                            </DockPanel>
                        </Button>
                        <Button Classes="navItem" Classes.selected="{Binding IsHistoryNavSelected}"
                                Command="{Binding SelectSectionCommand}" CommandParameter="History">
                            <TextBlock Text="{DynamicResource L.History}" />
                        </Button>
                        <Button Classes="navItem" Classes.selected="{Binding IsSearchNavSelected}"
                                Command="{Binding SelectSectionCommand}" CommandParameter="Search">
                            <TextBlock Text="{DynamicResource L.Search}" />
                        </Button>

                        <TextBox Text="{Binding SidebarFilter}" Watermark="{DynamicResource L.Filter}" Margin="2,8,2,2"
                                 Padding="6,3" FontSize="12" />

                        <ToggleButton Classes="sectionToggle" Name="BranchesToggle" IsChecked="True" Margin="0,6,0,0">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <Path Classes="chev" StrokeThickness="1.3" StrokeLineCap="Round"
                                      StrokeJoin="Round" Width="6" Height="10" Stretch="None" Data="M1,1 L5,5 L1,9" />
                                <Image Source="{DynamicResource I.Branch}" Width="13" Height="13" />
                                <TextBlock Classes="sectionHeader" Text="{DynamicResource L.Branches}" VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                        <StackPanel IsVisible="{Binding #BranchesToggle.IsChecked}">
                            <ItemsControl ItemsSource="{Binding Branches}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Classes="sideItem" Classes.selected="{Binding IsSelected}"
                                                Padding="22,3,8,3"
                                                PointerPressed="SidebarItem_PointerPressed"
                                                DoubleTapped="Branch_DoubleTapped">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="{DynamicResource L.Checkout}" Command="{Binding CheckoutCommand}" />
                                                    <MenuItem Header="{DynamicResource L.MergeInto}" Command="{Binding MergeCommand}" />
                                                    <Separator />
                                                    <MenuItem Header="{DynamicResource L.CopyBranchName}" Command="{Binding CopyNameCommand}" />
                                                    <MenuItem Header="{DynamicResource L.DeleteDots}" Command="{Binding DeleteCommand}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <DockPanel>
                                                <Border DockPanel.Dock="Right" Background="{DynamicResource B.Chip}" CornerRadius="7"
                                                        Padding="5,1" IsVisible="{Binding HasAheadBehind}">
                                                    <TextBlock Text="{Binding AheadBehind}" FontSize="10"
                                                               Foreground="{DynamicResource B.ChipText}" />
                                                </Border>
                                                <StackPanel Orientation="Horizontal" Spacing="6">
                                                    <TextBlock Text="○" FontSize="10" Foreground="#4A9EE0"
                                                               VerticalAlignment="Center" IsVisible="{Binding IsCurrent}" />
                                                    <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis"
                                                               FontWeight="{Binding IsCurrent, Converter={x:Static views:Converters.BoldIfTrue}}" />
                                                </StackPanel>
                                            </DockPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <ToggleButton Classes="sectionToggle" Name="TagsToggle" IsChecked="False">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <Path Classes="chev" StrokeThickness="1.3" StrokeLineCap="Round"
                                      StrokeJoin="Round" Width="6" Height="10" Stretch="None" Data="M1,1 L5,5 L1,9" />
                                <Image Source="{DynamicResource I.Tag}" Width="13" Height="13" />
                                <TextBlock Classes="sectionHeader" Text="{DynamicResource L.TagsHdr}" VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                        <StackPanel IsVisible="{Binding #TagsToggle.IsChecked}">
                            <ItemsControl ItemsSource="{Binding Tags}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Classes="sideItem" Classes.selected="{Binding IsSelected}"
                                                Padding="22,3,8,3"
                                                PointerPressed="SidebarItem_PointerPressed">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="{DynamicResource L.DeleteDots}" Command="{Binding DeleteCommand}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <ToggleButton Classes="sectionToggle" Name="RemotesToggle" IsChecked="False">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <Path Classes="chev" StrokeThickness="1.3" StrokeLineCap="Round"
                                      StrokeJoin="Round" Width="6" Height="10" Stretch="None" Data="M1,1 L5,5 L1,9" />
                                <Image Source="{DynamicResource I.Cloud}" Width="13" Height="13" />
                                <TextBlock Classes="sectionHeader" Text="{DynamicResource L.Remotes}" VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                        <StackPanel IsVisible="{Binding #RemotesToggle.IsChecked}">
                            <ItemsControl ItemsSource="{Binding Remotes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel>
                                            <TextBlock Text="{Binding Name}" Margin="22,3,8,3" FontWeight="SemiBold"
                                                       ToolTip.Tip="{Binding Url}" />
                                            <ItemsControl ItemsSource="{Binding Branches}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Classes="sideItem" Classes.selected="{Binding IsSelected}"
                                                                Padding="34,2,8,2"
                                                                PointerPressed="SidebarItem_PointerPressed"
                                                                DoubleTapped="RemoteBranch_DoubleTapped">
                                                            <Border.ContextMenu>
                                                                <ContextMenu>
                                                                    <MenuItem Header="{DynamicResource L.Checkout}" Command="{Binding CheckoutCommand}" />
                                                                </ContextMenu>
                                                            </Border.ContextMenu>
                                                            <TextBlock Text="{Binding Name}" Classes="dim"
                                                                       TextTrimming="CharacterEllipsis" />
                                                        </Border>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <ToggleButton Classes="sectionToggle" Name="StashesToggle" IsChecked="False">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <Path Classes="chev" StrokeThickness="1.3" StrokeLineCap="Round"
                                      StrokeJoin="Round" Width="6" Height="10" Stretch="None" Data="M1,1 L5,5 L1,9" />
                                <Image Source="{DynamicResource I.Stash}" Width="13" Height="13" />
                                <TextBlock Classes="sectionHeader" Text="{DynamicResource L.Stashes}" VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                        <StackPanel IsVisible="{Binding #StashesToggle.IsChecked}">
                            <ItemsControl ItemsSource="{Binding Stashes}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Classes="sideItem" Classes.selected="{Binding IsSelected}"
                                                Padding="22,3,8,3" ToolTip.Tip="{Binding DateText}"
                                                PointerPressed="SidebarItem_PointerPressed">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="{DynamicResource L.Apply}" Command="{Binding ApplyCommand}" />
                                                    <MenuItem Header="{DynamicResource L.ApplyPop}" Command="{Binding PopCommand}" />
                                                    <Separator />
                                                    <MenuItem Header="{DynamicResource L.DeleteDots}" Command="{Binding DropCommand}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <TextBlock Text="{Binding Title}" TextTrimming="CharacterEllipsis" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                        <ToggleButton Classes="sectionToggle" Name="SubmodulesToggle" IsChecked="False">
                            <StackPanel Orientation="Horizontal" Spacing="7">
                                <Path Classes="chev" StrokeThickness="1.3" StrokeLineCap="Round"
                                      StrokeJoin="Round" Width="6" Height="10" Stretch="None" Data="M1,1 L5,5 L1,9" />
                                <Image Source="{DynamicResource I.Submodule}" Width="13" Height="13" />
                                <TextBlock Classes="sectionHeader" Text="{DynamicResource L.Submodules}" VerticalAlignment="Center" />
                            </StackPanel>
                        </ToggleButton>
                        <StackPanel IsVisible="{Binding #SubmodulesToggle.IsChecked}">
                            <ItemsControl ItemsSource="{Binding Submodules}">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Classes="sideItem" Classes.selected="{Binding IsSelected}"
                                                Padding="22,3,8,3" ToolTip.Tip="{Binding PathText}"
                                                PointerPressed="SidebarItem_PointerPressed"
                                                DoubleTapped="Submodule_DoubleTapped">
                                            <Border.ContextMenu>
                                                <ContextMenu>
                                                    <MenuItem Header="{DynamicResource L.OpenRepository}" Command="{Binding OpenCommand}" />
                                                    <MenuItem Header="{DynamicResource L.UpdateSubmodule}" Command="{Binding UpdateCommand}" />
                                                </ContextMenu>
                                            </Border.ContextMenu>
                                            <TextBlock Text="{Binding Name}" TextTrimming="CharacterEllipsis" />
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>
            </Border>

            <GridSplitter Grid.Column="1" ResizeDirection="Columns" />

            <Panel Grid.Column="2" Background="{DynamicResource B.Content}">
                <views:HistoryView IsVisible="{Binding IsHistorySelected}" />
                <views:FileStatusView IsVisible="{Binding IsFileStatusSelected}" />
                <views:SearchView IsVisible="{Binding IsSearchSelected}" />
            </Panel>
        </Grid>
    </DockPanel>
</UserControl>
