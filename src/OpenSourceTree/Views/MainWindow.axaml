<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:OpenSourceTree.ViewModels"
        xmlns:views="using:OpenSourceTree.Views"
        x:Class="OpenSourceTree.Views.MainWindow"
        Title="OpenSourceTree"
        Width="1400" Height="860"
        MinWidth="900" MinHeight="560"
        ExtendClientAreaToDecorationsHint="True"
        ExtendClientAreaChromeHints="PreferSystemChrome"
        ExtendClientAreaTitleBarHeightHint="36"
        Icon="avares://OpenSourceTree/Assets/icon.ico"
        Background="#1C2733">

    <Window.DataTemplates>
        <DataTemplate DataType="{x:Type vm:RepositoryViewModel}">
            <views:RepositoryView />
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NewTabViewModel}">
            <views:NewTabView />
        </DataTemplate>
    </Window.DataTemplates>

    <DockPanel>

        <!-- ===== Custom title bar with repository tabs ===== -->
        <Border Name="TitleBar" DockPanel.Dock="Top" Height="36" Background="#0E1822"
                PointerPressed="TitleBar_PointerPressed" DoubleTapped="TitleBar_DoubleTapped">
            <DockPanel LastChildFill="True">
                <Image DockPanel.Dock="Left" Source="avares://OpenSourceTree/Assets/icon.png"
                       Width="20" Height="20" VerticalAlignment="Center" Margin="10,0,8,0" />
                <Border DockPanel.Dock="Right" Width="140" />  <!-- space for caption buttons -->
                <ScrollViewer HorizontalScrollBarVisibility="Hidden" VerticalScrollBarVisibility="Disabled">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom">
                        <ItemsControl ItemsSource="{Binding Tabs}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="1" />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Classes="tabChip" Classes.active="{Binding IsActive}"
                                            Height="28" MinWidth="110" MaxWidth="200"
                                            CornerRadius="4,4,0,0" Margin="0"
                                            PointerPressed="Tab_PointerPressed">
                                        <DockPanel Margin="10,0,4,0">
                                            <Button DockPanel.Dock="Right" Content="✕" FontSize="9"
                                                    Background="Transparent" BorderThickness="0"
                                                    Foreground="#7E92A5" Padding="4,2"
                                                    VerticalAlignment="Center"
                                                    Command="{Binding $parent[Window].DataContext.CloseTabCommand}"
                                                    CommandParameter="{Binding}" />
                                            <TextBlock Text="{Binding Title}" VerticalAlignment="Center"
                                                       Foreground="#C2D1DF" FontSize="12"
                                                       TextTrimming="CharacterEllipsis" />
                                        </DockPanel>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                        <Button Content="+" FontSize="15" Padding="8,0" Margin="4,0,0,2"
                                Background="Transparent" BorderThickness="0" Foreground="#7E92A5"
                                VerticalAlignment="Center"
                                Command="{Binding NewTabCommand}" />
                    </StackPanel>
                </ScrollViewer>
            </DockPanel>
        </Border>

        <!-- ===== Menu bar ===== -->
        <Border DockPanel.Dock="Top" Background="#13202C" BorderBrush="#0B141D" BorderThickness="0,0,0,1">
            <Menu>
                <MenuItem Header="_File">
                    <MenuItem Header="New Tab" InputGesture="Ctrl+T" Command="{Binding NewTabCommand}" />
                    <MenuItem Header="Open Repository…" InputGesture="Ctrl+O" Command="{Binding OpenRepositoryDialogCommand}" />
                    <Separator />
                    <MenuItem Header="Exit" Click="Exit_Click" />
                </MenuItem>
                <MenuItem Header="_Edit">
                    <MenuItem Header="Undo" InputGesture="Ctrl+Z" Click="EditUndo_Click" />
                    <MenuItem Header="Redo" InputGesture="Ctrl+Y" Click="EditRedo_Click" />
                    <Separator />
                    <MenuItem Header="Cut" InputGesture="Ctrl+X" Click="EditCut_Click" />
                    <MenuItem Header="Copy" InputGesture="Ctrl+C" Click="EditCopy_Click" />
                    <MenuItem Header="Paste" InputGesture="Ctrl+V" Click="EditPaste_Click" />
                    <Separator />
                    <MenuItem Header="Select All" InputGesture="Ctrl+A" Click="EditSelectAll_Click" />
                </MenuItem>
                <MenuItem Header="_View">
                    <MenuItem Header="File Status" Command="{Binding ActiveRepository.SelectSectionCommand}" CommandParameter="FileStatus" />
                    <MenuItem Header="History" Command="{Binding ActiveRepository.SelectSectionCommand}" CommandParameter="History" />
                    <MenuItem Header="Search" Command="{Binding ActiveRepository.SelectSectionCommand}" CommandParameter="Search" />
                    <Separator />
                    <MenuItem Header="Refresh" InputGesture="F5" Command="{Binding ActiveRepository.RefreshCommand}" />
                </MenuItem>
                <MenuItem Header="_Repository">
                    <MenuItem Header="Commit…" Command="{Binding ActiveRepository.ShowCommitViewCommand}" />
                    <MenuItem Header="Fetch" Command="{Binding ActiveRepository.FetchCommand}" />
                    <MenuItem Header="Pull" Command="{Binding ActiveRepository.PullCommand}" />
                    <MenuItem Header="Push" Command="{Binding ActiveRepository.PushCommand}" />
                    <Separator />
                    <MenuItem Header="Git Flow…" Command="{Binding ActiveRepository.GitFlowCommand}" />
                    <Separator />
                    <MenuItem Header="Add Submodule…" Command="{Binding ActiveRepository.AddSubmoduleCommand}" />
                    <MenuItem Header="Update Submodules" Command="{Binding ActiveRepository.UpdateSubmodulesCommand}" />
                    <Separator />
                    <MenuItem Header="Settings…" Command="{Binding ActiveRepository.OpenSettingsCommand}" />
                </MenuItem>
                <MenuItem Header="_Actions">
                    <MenuItem Header="New Branch…" Command="{Binding ActiveRepository.NewBranchCommand}" />
                    <MenuItem Header="Merge…" Command="{Binding ActiveRepository.MergeCommand}" />
                    <MenuItem Header="Stash Changes…" Command="{Binding ActiveRepository.StashChangesCommand}" />
                    <MenuItem Header="New Tag…" Command="{Binding ActiveRepository.NewTagCommand}" />
                    <Separator />
                    <MenuItem Header="Open in Terminal" Command="{Binding ActiveRepository.OpenTerminalCommand}" />
                    <MenuItem Header="Open in File Explorer" Command="{Binding ActiveRepository.OpenExplorerCommand}" />
                </MenuItem>
                <MenuItem Header="_Tools">
                    <MenuItem Header="Launch SSH Agent" Command="{Binding LaunchSshAgentCommand}" />
                    <MenuItem Header="Add SSH Key… (open ~/.ssh)" Command="{Binding OpenSshFolderCommand}" />
                    <MenuItem Header="Generate SSH Key…" Command="{Binding GenerateSshKeyCommand}" />
                    <Separator />
                    <MenuItem Header="Options…" Command="{Binding OpenOptionsCommand}" />
                </MenuItem>
                <MenuItem Header="_Help">
                    <MenuItem Header="Getting Started (README)" Command="{Binding OpenReadmeCommand}" />
                    <MenuItem Header="Keyboard Shortcuts" Command="{Binding ShowShortcutsCommand}" />
                    <Separator />
                    <MenuItem Header="About OpenSourceTree" Command="{Binding AboutCommand}" />
                </MenuItem>
            </Menu>
        </Border>

        <!-- ===== Active tab content ===== -->
        <ContentControl Content="{Binding ActiveTab}" />
    </DockPanel>
</Window>
