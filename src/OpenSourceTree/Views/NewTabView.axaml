<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:views="using:OpenSourceTree.Views"
             x:Class="OpenSourceTree.Views.NewTabView">

    <DockPanel>

        <!-- ===== Top button row: Local / Remote | Clone / Add / New (like SourceTree) ===== -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource B.Toolbar}"
                BorderBrush="{DynamicResource B.Border}" BorderThickness="0,0,0,1">
            <StackPanel Orientation="Horizontal" Spacing="2" Margin="10,4">
                <Button Classes="toolbar" Classes.selected="{Binding IsLocalSelected}"
                        Command="{Binding SelectSectionCommand}" CommandParameter="Local">
                    <StackPanel Spacing="3">
                        <Image Source="{DynamicResource I.Workspace}" Width="16" Height="16" />
                        <TextBlock Text="{DynamicResource L.Local}" />
                    </StackPanel>
                </Button>
                <Button Classes="toolbar" Classes.selected="{Binding IsRemoteSelected}"
                        Command="{Binding SelectSectionCommand}" CommandParameter="Remote">
                    <StackPanel Spacing="3">
                        <Image Source="{DynamicResource I.Cloud}" Width="16" Height="16" />
                        <TextBlock Text="{DynamicResource L.Remote}" />
                    </StackPanel>
                </Button>

                <Border Width="1" Background="{DynamicResource B.Divider}" Margin="8,6" />

                <Button Classes="toolbar" Classes.selected="{Binding IsCloneSelected}"
                        Command="{Binding SelectSectionCommand}" CommandParameter="Clone">
                    <StackPanel Spacing="3">
                        <Image Source="{DynamicResource I.Pull}" Width="16" Height="16" />
                        <TextBlock Text="{DynamicResource L.Clone}" />
                    </StackPanel>
                </Button>
                <Button Classes="toolbar" Classes.selected="{Binding IsAddSelected}"
                        Command="{Binding SelectSectionCommand}" CommandParameter="Add">
                    <StackPanel Spacing="3">
                        <Image Source="{DynamicResource I.Explorer}" Width="16" Height="16" />
                        <TextBlock Text="{DynamicResource L.Add}" />
                    </StackPanel>
                </Button>
                <Button Classes="toolbar" Classes.selected="{Binding IsNewSelected}"
                        Command="{Binding SelectSectionCommand}" CommandParameter="New">
                    <StackPanel Spacing="3">
                        <Image Source="{DynamicResource I.Plus}" Width="16" Height="16" />
                        <TextBlock Text="{DynamicResource L.New}" />
                    </StackPanel>
                </Button>
            </StackPanel>
        </Border>

        <Panel Background="{DynamicResource B.Content}">

            <!-- ===== Local repositories ===== -->
            <DockPanel IsVisible="{Binding IsLocalSelected}" Margin="26,18,26,0">
                <TextBlock DockPanel.Dock="Top" Text="{DynamicResource L.LocalRepos}"
                           FontSize="24" FontWeight="Light" Margin="0,0,0,14" />
                <TextBox DockPanel.Dock="Top" Text="{Binding LocalFilter}" Watermark="{DynamicResource L.Search}"
                         MaxWidth="560" HorizontalAlignment="Left" MinWidth="420" />
                <TextBlock DockPanel.Dock="Top" Classes="dim" Margin="2,12,0,0"
                           Text="{DynamicResource L.LocalHint}"
                           IsVisible="{Binding !HasLocalRepos}" />

                <!-- Bottom status bar (like SourceTree's Local view) -->
                <Border DockPanel.Dock="Bottom" BorderBrush="{DynamicResource B.Border}" BorderThickness="0,1,0,0"
                        Background="{DynamicResource B.Input}" Margin="-26,10,-26,0" Padding="14,5">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <Button Content="{DynamicResource L.Refresh}" FontSize="11" Padding="10,3"
                                Command="{Binding RefreshLocalCommand}" />
                        <Button Content="{DynamicResource L.ShowInExplorer}" FontSize="11" Padding="10,3"
                                IsEnabled="{Binding HasLocalSelection}"
                                Command="{Binding OpenLocalInExplorerCommand}" />
                        <Button Content="{DynamicResource L.OpenInTerminal}" FontSize="11" Padding="10,3"
                                IsEnabled="{Binding HasLocalSelection}"
                                Command="{Binding OpenLocalInTerminalCommand}" />
                    </StackPanel>
                </Border>

                <ListBox Name="LocalList" ItemsSource="{Binding LocalRepos}" Margin="0,10,0,0"
                         SelectedItem="{Binding SelectedLocal}"
                         MaxWidth="560" HorizontalAlignment="Left" MinWidth="420"
                         DoubleTapped="LocalRepo_DoubleTapped">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="2,3">
                                <Border Width="30" Height="30" CornerRadius="15" Background="{DynamicResource B.Chip}"
                                        VerticalAlignment="Center">
                                    <Image Source="{DynamicResource I.Branch}" Width="15" Height="15"
                                           HorizontalAlignment="Center" VerticalAlignment="Center" />
                                </Border>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding Name}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <Border Background="{DynamicResource B.Chip}" CornerRadius="3" Padding="5,1"
                                                VerticalAlignment="Center" IsVisible="{Binding HasBranch}">
                                            <TextBlock Text="{Binding Branch}" FontSize="10"
                                                       Foreground="{DynamicResource B.ChipText}" />
                                        </Border>
                                        <Ellipse Width="7" Height="7" Fill="#E8A33D"
                                                 VerticalAlignment="Center" IsVisible="{Binding IsDirty}"
                                                 ToolTip.Tip="Uncommitted changes" />
                                    </StackPanel>
                                    <TextBlock Text="{Binding Path}" Classes="dim" FontSize="11" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- ===== Remote (hosting accounts) ===== -->
            <DockPanel IsVisible="{Binding IsRemoteSelected}" Margin="26,18,26,18">
                <TextBlock DockPanel.Dock="Top" Text="{DynamicResource L.RemoteRepos}"
                           FontSize="24" FontWeight="Light" Margin="0,0,0,14" />

                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="6">
                    <ComboBox MinWidth="240" ItemsSource="{Binding Accounts}"
                              SelectedItem="{Binding SelectedAccount}">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding Display}" />
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>
                    <Button Content="{DynamicResource L.AddAccount}" Padding="10,4" Command="{Binding AddAccountCommand}" />
                    <Button Content="{DynamicResource L.Remove}" Padding="10,4" Command="{Binding RemoveAccountCommand}"
                            IsEnabled="{Binding HasSelectedAccount}" />
                    <Button Content="{DynamicResource L.Refresh}" Padding="10,4" Command="{Binding RefreshRemoteCommand}"
                            IsEnabled="{Binding HasSelectedAccount}" />
                </StackPanel>

                <TextBox DockPanel.Dock="Top" Text="{Binding RemoteFilter}" Watermark="{DynamicResource L.Search}"
                         MaxWidth="560" HorizontalAlignment="Left" MinWidth="420" Margin="0,10,0,0" />

                <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Spacing="8" Margin="2,8,0,0">
                    <ProgressBar IsIndeterminate="True" Width="90" Height="3"
                                 IsVisible="{Binding IsRemoteLoading}" Foreground="#4A9EE0" />
                    <TextBlock Classes="dim" Text="{Binding RemoteStatus}" TextWrapping="Wrap" />
                </StackPanel>

                <ListBox Name="RemoteList" ItemsSource="{Binding RemoteRepos}" Margin="0,8,0,0"
                         DoubleTapped="RemoteRepo_DoubleTapped">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="10" Margin="2,3">
                                <Border Width="30" Height="30" CornerRadius="15" Background="{DynamicResource B.Chip}"
                                        VerticalAlignment="Center" ClipToBounds="True">
                                    <Panel>
                                        <Image Source="{DynamicResource I.Cloud}" Width="15" Height="15"
                                               HorizontalAlignment="Center" VerticalAlignment="Center"
                                               IsVisible="{Binding !HasAvatar}" />
                                        <Image Source="{Binding Avatar}" Width="30" Height="30"
                                               Stretch="UniformToFill" IsVisible="{Binding HasAvatar}" />
                                    </Panel>
                                </Border>
                                <StackPanel VerticalAlignment="Center" Spacing="2">
                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                        <TextBlock Text="{Binding FullName}" FontWeight="SemiBold"
                                                   VerticalAlignment="Center" />
                                        <Border Background="#52453A" CornerRadius="3" Padding="5,1"
                                                VerticalAlignment="Center" IsVisible="{Binding IsPrivate}">
                                            <TextBlock Text="private" FontSize="10" Foreground="#E8EEF4" />
                                        </Border>
                                    </StackPanel>
                                    <TextBlock Text="{Binding Description}" Classes="dim" FontSize="11"
                                               TextTrimming="CharacterEllipsis" MaxWidth="640"
                                               HorizontalAlignment="Left"
                                               IsVisible="{Binding Description.Length}" />
                                </StackPanel>
                            </StackPanel>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>

            <!-- ===== Clone ===== -->
            <StackPanel IsVisible="{Binding IsCloneSelected}" Margin="26,18" Spacing="10"
                        MaxWidth="620" HorizontalAlignment="Left">
                <TextBlock Text="{DynamicResource L.Clone}" FontSize="24" FontWeight="Light" Margin="0,0,0,6" />
                <TextBlock Text="{DynamicResource L.SourceUrl}" Classes="dim" FontSize="12" />
                <TextBox Text="{Binding CloneUrl}" Watermark="https://… or git@…" />
                <TextBlock Text="{DynamicResource L.DestPath}" Classes="dim" FontSize="12" />
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="{DynamicResource L.Browse}" Margin="6,0,0,0"
                            Command="{Binding BrowseCloneParentCommand}" />
                    <TextBox Text="{Binding CloneParent}" Watermark="{DynamicResource L.ParentFolderWm}" />
                </DockPanel>
                <TextBlock Text="{DynamicResource L.NameLbl}" Classes="dim" FontSize="12" />
                <TextBox Text="{Binding CloneName}" Watermark="{DynamicResource L.FolderNameWm}" MaxWidth="300"
                         HorizontalAlignment="Left" MinWidth="300" />
                <TextBlock Classes="dim" FontSize="11" Text="{Binding CloneTargetPreview, StringFormat='→ {0}'}" />
                <Button Classes="accent" Content="{DynamicResource L.Clone}" Padding="22,5" Margin="0,8,0,0"
                        HorizontalAlignment="Left" Command="{Binding CloneCommand}" />
            </StackPanel>

            <!-- ===== Add (existing local repository) ===== -->
            <StackPanel IsVisible="{Binding IsAddSelected}" Margin="26,18" Spacing="10"
                        MaxWidth="620" HorizontalAlignment="Left">
                <TextBlock Text="{DynamicResource L.Add}" FontSize="24" FontWeight="Light" Margin="0,0,0,6" />
                <TextBlock Text="{DynamicResource L.WorkingCopy}" Classes="dim" FontSize="12" />
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="{DynamicResource L.Browse}" Margin="6,0,0,0"
                            Command="{Binding BrowseAddCommand}" />
                    <TextBox Text="{Binding AddPath}" Watermark="{DynamicResource L.RepoPathWm}" />
                </DockPanel>
                <Button Classes="accent" Content="{DynamicResource L.Add}" Padding="22,5" Margin="0,8,0,0"
                        HorizontalAlignment="Left" Command="{Binding AddRepositoryCommand}" />
            </StackPanel>

            <!-- ===== New (create repository) ===== -->
            <StackPanel IsVisible="{Binding IsNewSelected}" Margin="26,18" Spacing="10"
                        MaxWidth="620" HorizontalAlignment="Left">
                <TextBlock Text="{DynamicResource L.CreateRepo}" FontSize="24" FontWeight="Light" Margin="0,0,0,6" />
                <TextBlock Text="{DynamicResource L.DestPath}" Classes="dim" FontSize="12" />
                <DockPanel>
                    <Button DockPanel.Dock="Right" Content="{DynamicResource L.Browse}" Margin="6,0,0,0"
                            Command="{Binding BrowseCreateCommand}" />
                    <TextBox Text="{Binding CreatePath}" Watermark="{DynamicResource L.NewRepoFolderWm}" />
                </DockPanel>
                <Button Classes="accent" Content="{DynamicResource L.New}" Padding="22,5" Margin="0,8,0,0"
                        HorizontalAlignment="Left" Command="{Binding CreateCommand}" />
            </StackPanel>

        </Panel>
    </DockPanel>
</UserControl>
